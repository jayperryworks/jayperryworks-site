---
/**
 * Book Card layout component
 * -> display a cover image and info about a book
 *
 * @param {object} [links] - info/purchase links to display
 * @param {string} [author] - the author's name
 * @param {string} [class] - append classes to the container
 * @param {Cover} [cover] - the cover image url
 * @param {string[]} [tags] - category tags for the book
 * @param {string} [title] - the book's title
 */

// --- assets ---
import '@shared/styles/tokens/borders.css';
import '@shared/styles/tokens/contentWidth.css';
import '@shared/styles/tokens/spacing.css';
import '@shared/styles/tokens/type.css';
import '@shared/styles/utilities/type.css';
import externalLink from '@shared/icons/external-link.svg?raw';

// --- utilities ---
import { removeArticles } from '@shared/lib/stringHelpers';

// --- components ---
import Button from '@shared/components/elements/Button.astro';
import Heading from '@shared/components/blocks/Heading.astro';
import RevealOnScroll from '@shared/components/meta/RevealOnScroll.astro';
import { Image } from 'astro:assets';

// --- types ---
/** @typedef {object} Action
 * @prop {string} label - text label to display on the button
 * @prop {string} url
 * @prop {'external' | 'internal'} type - does the url link to a page or another site?
 */

/**
 * @typedef {object} Cover
 * @prop {number} height - height of the image in pixels
 * @prop {string} uuid - permalink on server
 * @prop {string} url - current location on server
 * @prop {number} width - width of the image in pixels
 * @prop {number} [rank] - preference for which cover to use (lower = better)
 */

// --- props ---
const {
	author,
	class: className = '',
	cover,
	links,
	tags = [],
	title,
} = Astro.props;

// set up data for the ButtonCard's actions prop
const actions = Object.keys(links).map((label) => ({
	url: links[label],
	label,
}));

/**
 * Get the initial letter from the title of a book
 *
 * @function
 * @param {string} title - the book's title
 * @returns {string}
 */
function getInitial(title) {
	return removeArticles(title).charAt(0).toUpperCase();
}

/**
 * Set the height/width styles for the cover image based on its aspect ratio
 *
 * @function
 * @param {object} cover
 * @param {number} cover.width
 * @param {number} cover.height
 * @returns {string}
 */
function setImageStyle({ width, height }) {
	const aspect = Number((width / height).toFixed(2));

	return aspect > 1 ? 'width: 100%; max-height: 100%;' : 'height: 100%';
}
---

<article class={['book-card', className].join(' ').trim()}>
	<div class="wrapper">
		<!-- cover -->
		<RevealOnScroll
			tag="figure"
			class="cover"
		>
			<slot name="cover">
				{
					cover ? (
						<Image
							src={cover.url}
							alt={`Cover for '${title}'`}
							class="cover-image"
							height={cover.height}
							sizes={`(min-width: 1200px) 600px, (min-width: 600px) 300px, 180px`}
							style={setImageStyle(cover)}
							width={cover.width}
							widths={[180, 300, 600]}
						/>
					) : (
						<div class="cover-image placeholder">
							<p class="type-role-display type-scale-alpha">
								{getInitial(title)}
							</p>
						</div>
					)
				}
			</slot>
		</RevealOnScroll>

		<!-- title, author, etc. -->
		<div class="title-lockup">
			<slot name="title">
				{
					title && (
						<Heading
							class="type-scale-epsilon"
							level={2}
						>
							{title}
						</Heading>
					)
				}
				{
					author && (
						<Heading
							level={5}
							subheading
						>
							{author}
						</Heading>
					)
				}
			</slot>
		</div>

		<!-- book metadata -->
		{
			Astro.slots.has() && (
				<div class="metadata">
					<slot name="metadata" />
				</div>
			)
		}

		<!-- actions -->
		{
			actions && (
				<footer class="actions">
					{actions.map(({ label, url }) => (
						<Button
							href={url}
							iconRight={externalLink}
							class="type-role-accent"
							size="small"
							target="_blank"
						>
							{label}
						</Button>
					))}
				</footer>
			)
		}
	</div>
</article>

<style>
	.book-card {
		--cover-size: 10em;

		background-color: var(--color-island);
		border-radius: var(--border-radius-round);
		container-type: inline-size;
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: var(--space-medium) var(--space-xnarrow);
	}

	.wrapper {
		align-items: center;
		justify-content: center;
		display: grid;
		flex: 1;
		grid-template-areas:
			'cover'
			'header'
			'metadata'
			'actions';
		grid-template-rows:
			var(--cover-size)
			auto
			auto
			1fr;
		text-align: center;
	}

	.book-card :global(.cover) {
		align-items: center;
		align-self: stretch;
		aspect-ratio: 1 / 1;
		container-type: normal;
		display: flex;
		grid-area: cover;
		height: 100%;
		justify-content: center;
		justify-self: center;
		width: 100%;
	}

	.book-card :global(.cover-image) {
		box-shadow: 0.25em 0.3em 0.4em var(--color-shadow);
		display: block;
	}

	.cover-image.placeholder {
		align-items: center;
		aspect-ratio: 1 / 1.2;
		background-color: var(--color-surface);
		border: var(--border-solid);
		box-shadow: 0;
		color: var(--color-border);
		display: flex;
		flex-direction: column;
		height: 100%;
		justify-content: center;
		padding-block-start: 0.8rem; /* scoot the initial down a little to optically align it/compensate for line height */
	}

	.title-lockup {
		grid-area: header;
		padding-block-start: var(--space-medium);
	}

	.metadata {
		grid-area: metadata;
		padding-block-start: var(--space-xnarrow);
	}

	.actions {
		align-items: center;
		align-self: end;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: var(--space-xnarrow);
		grid-area: actions;
		justify-content: center;
		padding-block-start: var(--space-narrow);
	}

	@container (min-width: 28em) {
		.wrapper {
			align-items: start;
			justify-content: start;
			gap: var(--space-xnarrow) var(--space-narrow);
			grid-template-areas:
				'cover header'
				'cover metadata'
				'cover actions';
			grid-template-columns: var(--cover-size) 1fr;
			grid-template-rows:
				auto
				auto
				1fr;
			flex: 1;
			text-align: start;
		}

		.cover {
			align-self: start;
			height: 100%;
			justify-content: center;
			width: 100%;
		}

		header,
		.metadata,
		.actions {
			padding-block-start: 0;
		}

		.actions {
			justify-content: start;
		}
	}
</style>
